<svg width="100%" height="180" viewBox="0 0 600 180" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="sbg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#03050C"/>
      <stop offset="100%" stop-color="#1E293B"/>
    </linearGradient>
    <radialGradient id="shalo" cx="0.5" cy="0.5" r="0.6">
      <stop offset="0%" stop-color="#A78BFA" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#03050C" stop-opacity="0"/>
    </radialGradient>
    <style>
      .sl { font: 700 16px ui-monospace, monospace; fill: #22D3EE; letter-spacing: 0.3em; }
      .sm { font: 400 10px ui-monospace, monospace; fill: #94A3B8; letter-spacing: 0.2em; }
      .code { font: 400 9px ui-monospace, monospace; }
    </style>
  </defs>
  <rect width="600" height="180" rx="10" fill="url(#sbg)"/>
  <circle cx="300" cy="90" r="140" fill="url(#shalo)"/>

  <!-- Code editor mock -->
  <g transform="translate(60,60)">
    <rect width="240" height="100" rx="6" fill="#0A1228" stroke="#22D3EE" stroke-width="1" opacity="0.9"/>
    <!-- traffic lights -->
    <circle cx="12" cy="12" r="3" fill="#EF4444"/>
    <circle cx="24" cy="12" r="3" fill="#F59E0B"/>
    <circle cx="36" cy="12" r="3" fill="#10B981"/>
    <line x1="0" y1="22" x2="240" y2="22" stroke="#22D3EE" stroke-width="0.5" opacity="0.3"/>

    <!-- code lines -->
    <text x="12" y="38" class="code" fill="#A78BFA">const</text>
    <text x="48" y="38" class="code" fill="#22D3EE">build</text>
    <text x="80" y="38" class="code" fill="#cbd5e1">= async () =&gt; {</text>

    <text x="20" y="52" class="code" fill="#94A3B8">await</text>
    <text x="55" y="52" class="code" fill="#22D3EE">deploy</text>
    <text x="92" y="52" class="code" fill="#cbd5e1">(</text>
    <text x="98" y="52" class="code" fill="#F59E0B">'prod'</text>
    <text x="130" y="52" class="code" fill="#cbd5e1">)</text>

    <text x="20" y="66" class="code" fill="#94A3B8">return</text>
    <text x="60" y="66" class="code" fill="#10B981">'shipped'</text>

    <text x="12" y="80" class="code" fill="#cbd5e1">}</text>

    <!-- blinking cursor -->
    <rect x="30" y="86" width="6" height="10" fill="#22D3EE">
      <animate attributeName="opacity" values="0;0;1;1" dur="1s" repeatCount="indefinite"/>
    </rect>
  </g>

  <!-- Full-stack layers -->
  <g transform="translate(440,90)">
    <!-- Frontend -->
    <rect x="-50" y="-50" width="100" height="22" rx="3" fill="none" stroke="#22D3EE" stroke-width="1.2">
      <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" repeatCount="indefinite"/>
    </rect>
    <text x="0" y="-35" class="code" text-anchor="middle" fill="#22D3EE">FRONTEND</text>

    <!-- API -->
    <rect x="-50" y="-15" width="100" height="22" rx="3" fill="none" stroke="#A78BFA" stroke-width="1.2">
      <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" begin="0.5s" repeatCount="indefinite"/>
    </rect>
    <text x="0" y="0" class="code" text-anchor="middle" fill="#A78BFA">API</text>

    <!-- Backend -->
    <rect x="-50" y="20" width="100" height="22" rx="3" fill="none" stroke="#7C3AED" stroke-width="1.2">
      <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" begin="1s" repeatCount="indefinite"/>
    </rect>
    <text x="0" y="35" class="code" text-anchor="middle" fill="#A78BFA">BACKEND</text>

    <!-- DB -->
    <ellipse cx="0" cy="56" rx="40" ry="6" fill="none" stroke="#22D3EE" stroke-width="1.2">
      <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" begin="1.5s" repeatCount="indefinite"/>
    </ellipse>
    <line x1="-40" y1="56" x2="-40" y2="64" stroke="#22D3EE" stroke-width="1.2"/>
    <line x1="40" y1="56" x2="40" y2="64" stroke="#22D3EE" stroke-width="1.2"/>
    <ellipse cx="0" cy="64" rx="40" ry="6" fill="none" stroke="#22D3EE" stroke-width="1.2"/>

    <!-- connecting arrows -->
    <line x1="0" y1="-28" x2="0" y2="-15" stroke="#22D3EE" stroke-width="1" stroke-dasharray="2,2">
      <animate attributeName="stroke-dashoffset" values="0;-8" dur="0.8s" repeatCount="indefinite"/>
    </line>
    <line x1="0" y1="7" x2="0" y2="20" stroke="#A78BFA" stroke-width="1" stroke-dasharray="2,2">
      <animate attributeName="stroke-dashoffset" values="0;-8" dur="0.8s" repeatCount="indefinite"/>
    </line>
    <line x1="0" y1="42" x2="0" y2="50" stroke="#7C3AED" stroke-width="1" stroke-dasharray="2,2">
      <animate attributeName="stroke-dashoffset" values="0;-8" dur="0.8s" repeatCount="indefinite"/>
    </line>
  </g>

  <text x="300" y="35" class="sl" text-anchor="middle">FULL-STACK ENGINEERING</text>
</svg>
