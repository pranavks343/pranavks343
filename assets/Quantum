<svg width="100%" height="180" viewBox="0 0 600 180" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="qbg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0A1228"/>
      <stop offset="100%" stop-color="#1E1B4B"/>
    </linearGradient>
    <radialGradient id="qhalo" cx="0.5" cy="0.5" r="0.6">
      <stop offset="0%" stop-color="#7C3AED" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#0A1228" stop-opacity="0"/>
    </radialGradient>
    <filter id="qglow"><feGaussianBlur stdDeviation="2"/></filter>
    <style>
      .ql { font: 700 16px ui-monospace, monospace; fill: #22D3EE; letter-spacing: 0.3em; }
      .qm { font: 400 10px ui-monospace, monospace; fill: #94A3B8; letter-spacing: 0.2em; }
    </style>
  </defs>
  <rect width="600" height="180" rx="10" fill="url(#qbg)"/>
  <circle cx="300" cy="90" r="120" fill="url(#qhalo)"/>

  <!-- Rotating Bloch Sphere -->
  <g transform="translate(120,90)">
    <circle r="50" fill="none" stroke="#22D3EE" stroke-width="1.2" opacity="0.5"/>
    <ellipse rx="50" ry="16" fill="none" stroke="#22D3EE" stroke-width="0.7" opacity="0.4">
      <animate attributeName="ry" values="16;8;16" dur="4s" repeatCount="indefinite"/>
    </ellipse>
    <ellipse rx="16" ry="50" fill="none" stroke="#A78BFA" stroke-width="0.7" opacity="0.4">
      <animate attributeName="rx" values="16;8;16" dur="4s" repeatCount="indefinite"/>
    </ellipse>
    <line x1="0" y1="-58" x2="0" y2="58" stroke="#94A3B8" stroke-width="0.5"/>
    <line x1="-58" y1="0" x2="58" y2="0" stroke="#94A3B8" stroke-width="0.5"/>
    <g>
      <animateTransform attributeName="transform" type="rotate" from="0" to="360" dur="6s" repeatCount="indefinite"/>
      <line x1="0" y1="0" x2="35" y2="-35" stroke="#22D3EE" stroke-width="2.5"/>
      <circle cx="35" cy="-35" r="4" fill="#22D3EE"/>
    </g>
    <text x="0" y="-65" class="qm" text-anchor="middle">|0⟩</text>
    <text x="0" y="75" class="qm" text-anchor="middle">|1⟩</text>
  </g>

  <!-- Entangled qubit pair -->
  <g transform="translate(480,90)">
    <circle cx="-30" cy="0" r="14" fill="none" stroke="#22D3EE" stroke-width="2">
      <animate attributeName="r" values="14;18;14" dur="2s" repeatCount="indefinite"/>
    </circle>
    <circle cx="30" cy="0" r="14" fill="none" stroke="#A78BFA" stroke-width="2">
      <animate attributeName="r" values="14;18;14" dur="2s" begin="1s" repeatCount="indefinite"/>
    </circle>
    <path d="M -16 0 Q 0 -25 16 0" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-dasharray="3,3">
      <animate attributeName="stroke-dashoffset" values="0;-12" dur="1s" repeatCount="indefinite"/>
    </path>
    <path d="M -16 0 Q 0 25 16 0" fill="none" stroke="#7C3AED" stroke-width="1.5" stroke-dasharray="3,3">
      <animate attributeName="stroke-dashoffset" values="0;12" dur="1s" repeatCount="indefinite"/>
    </path>
    <text x="-30" y="4" class="qm" text-anchor="middle">|ψ⟩</text>
    <text x="30" y="4" class="qm" text-anchor="middle">|φ⟩</text>
  </g>

  <text x="300" y="40" class="ql" text-anchor="middle">QUANTUM COMPUTING</text>
  <text x="300" y="155" class="qm" text-anchor="middle">QAOA · VQE · QISKIT · IBM HARDWARE</text>
</svg>
